PORT=3000

# LINE Developers > Messaging API channel
LINE_CHANNEL_SECRET=replace_with_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=replace_with_line_channel_access_token

# AI provider: openai or gemini
AI_PROVIDER=openai

# OpenAI Platform
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=replace_with_a_current_text_model

# Google Gemini API, set AI_PROVIDER=gemini to use these
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# Bot behavior
BOT_NAME=客服小幫手
BUSINESS_NAME=你的品牌名稱
REPLY_LANGUAGE=繁體中文
HUMAN_HANDOFF_TEXT=我已幫你記錄，稍後會由真人協助你。
